<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kolar.keepalive-cc-codex</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/kolar/.local/bin/keepalive-cc-codex.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/kolar/.local/var/log/keepalive-cc-codex.launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/kolar/.local/var/log/keepalive-cc-codex.launchd.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/kolar</string>
        <key>PATH</key>
        <string>/Users/kolar/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
